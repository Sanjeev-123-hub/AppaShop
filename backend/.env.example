# ═══════════════════════════════════════════════════════════
#  APPA GROCERIES — Backend Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git — add it to .gitignore!
# ═══════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Your frontend URL (used for CORS).
# In production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ── Google Gemini API ────────────────────────────────────────
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_YOUR_GEMINI_KEY_HERE

# ── Firebase Admin SDK ───────────────────────────────────────
#
# OPTION A (recommended for Vercel / Railway):
#   Paste the entire contents of your service-account JSON
#   as a single-line string (replace newlines with \n).
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_PROJECT_ID",...}

#
# OPTION B (local development):
#   Path to your downloaded service-account JSON file.
# FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# Optional — only needed if you use Firebase Realtime Database
# FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
